# Environment (development, staging, production)
VITE_APP_ENV=development

VITE_API_URL=http://localhost:3000
VITE_AUTH_API_URL=http://localhost:3001
VITE_EVOAI_API_URL=http://localhost:5555
VITE_EVOFLOW_API_URL=http://localhost:3334
VITE_AGENT_PROCESSOR_URL=http://localhost:8000
# VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# TinyMCE API Key (optional - used for email editor)
# To get a free key, visit: https://www.tiny.cloud/auth/signup/
VITE_TINYMCE_API_KEY=no-api-key
# Microsoft Clarity
# VITE_CLARITY_PROJECT_ID=your_clarity_project_id_here

# ─── FPLUS · Supabase (Sprint 1) ───────────────────────────────────────────
# URL y anon key son PÚBLICAS (seguras en el frontend).
# La service_role key y la contraseña de la DB van SOLO en .env.local del
# servidor / CI, NUNCA en el frontend ni en el repositorio (Principio 4).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Modo demo: sin estas variables, la app usa mock + localStorage (login admin/admin).
